#!/usr/bin/env bash
set -u

VERSION="V1.0.4"
API_BASE="${BOIL_API_BASE:-https://ippanel.boil.network/api/v1}"
UPDATE_URL="${BOIL_UPDATE_URL:-https://raw.githubusercontent.com/chnnic/Boil-Change-IP/main/boil}"
SSH_HARDENING_DDNS_URL="${BOIL_DDNS_URL:-https://raw.githubusercontent.com/chnnic/SSH-Hardening/refs/heads/main/SSH-Hardening.sh}"
SYSTEM_DIR="/etc/boil"
SYSTEM_TOKEN_FILE="$SYSTEM_DIR/token"
SYSTEM_STATE_FILE="$SYSTEM_DIR/state.json"

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf '缺少依赖: %s\n' "$1" >&2
    exit 1
  fi
}

require_deps() {
  require_command curl
  require_command python3
}

user_config_dir() {
  printf '%s\n' "${XDG_CONFIG_HOME:-${HOME:-/tmp}/.config}/boil"
}

user_state_dir() {
  printf '%s\n' "${XDG_STATE_HOME:-${HOME:-/tmp}/.local/state}/boil"
}

user_data_dir() {
  printf '%s\n' "${XDG_DATA_HOME:-${HOME:-/tmp}/.local/share}/boil"
}

current_script_path() {
  local script="$0"

  if [ -n "${BOIL_UPDATE_TARGET:-}" ]; then
    printf '%s\n' "$BOIL_UPDATE_TARGET"
    return 0
  fi

  if [ "$script" = "bash" ] || [ "$script" = "sh" ]; then
    script="$(command -v boil 2>/dev/null || true)"
  elif [ "${script#/}" = "$script" ]; then
    script="$(command -v "$script" 2>/dev/null || printf '%s/%s' "$PWD" "$script")"
  fi

  if command -v realpath >/dev/null 2>&1; then
    realpath "$script"
  elif command -v readlink >/dev/null 2>&1; then
    readlink -f "$script" 2>/dev/null || printf '%s\n' "$script"
  else
    printf '%s\n' "$script"
  fi
}

token_file() {
  if [ -n "${BOIL_TOKEN_FILE:-}" ]; then
    printf '%s\n' "$BOIL_TOKEN_FILE"
  elif [ -r "$SYSTEM_TOKEN_FILE" ] || [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' "$SYSTEM_TOKEN_FILE"
  else
    printf '%s/token\n' "$(user_config_dir)"
  fi
}

state_file() {
  if [ -n "${BOIL_STATE_FILE:-}" ]; then
    printf '%s\n' "$BOIL_STATE_FILE"
  elif [ -r "$SYSTEM_STATE_FILE" ] || [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' "$SYSTEM_STATE_FILE"
  else
    printf '%s/state.json\n' "$(user_state_dir)"
  fi
}

ddns_helper_file() {
  if [ -n "${BOIL_DDNS_HELPER:-}" ]; then
    printf '%s\n' "$BOIL_DDNS_HELPER"
  elif [ "$(id -u)" -eq 0 ]; then
    printf '%s\n' "/usr/local/lib/boil/ssh-hardening-ddns.sh"
  else
    printf '%s/ssh-hardening-ddns.sh\n' "$(user_data_dir)"
  fi
}

read_token() {
  if [ -n "${BOIL_TOKEN:-}" ]; then
    printf '%s\n' "$BOIL_TOKEN"
    return 0
  fi

  local file
  file="$(token_file)"
  [ -r "$file" ] || return 1

  python3 - "$file" <<'PY'
from pathlib import Path
import sys

path = Path(sys.argv[1])
for line in path.read_text(encoding="utf-8").splitlines():
    value = line.strip()
    if value:
        print(value)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

mask_token() {
  local token="$1"
  local length=${#token}

  if [ "$length" -le 8 ]; then
    printf '****\n'
  else
    printf '%s****%s\n' "${token:0:4}" "${token: -4}"
  fi
}

save_token() {
  local token="$1"
  local file dir

  file="$(token_file)"
  dir="$(dirname "$file")"
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true

  umask 077
  printf '%s\n' "$token" >"$file"
  chmod 600 "$file" 2>/dev/null || true

  printf 'API Token 已保存到: %s\n' "$file"
}

prompt_token() {
  local token

  printf '请输入 Boil API Token（输入会显示，粘贴后按 Enter）: '
  IFS= read -r token

  if [ -z "$token" ]; then
    printf 'Token 不能为空。\n'
    return 1
  fi

  save_token "$token"
}

json_value() {
  local key="$1"

  JSON_KEY="$key" python3 -c '
import json
import os
import sys

key = os.environ["JSON_KEY"]
try:
    data = json.load(sys.stdin)
    value = data
    for part in key.split("."):
        value = value[part]
except Exception:
    raise SystemExit(1)

if value is None:
    raise SystemExit(1)
if isinstance(value, bool):
    print("true" if value else "false")
else:
    print(value)
'
}

format_time() {
  local value="$1"

  if [ -z "$value" ]; then
    return 1
  fi

  python3 - "$value" <<'PY'
from datetime import datetime
import sys

value = sys.argv[1]
try:
    ts = int(float(value))
except Exception:
    print(value)
else:
    print(datetime.fromtimestamp(ts).strftime("%Y-%m-%d %H:%M:%S"))
PY
}

api_post() {
  local endpoint="$1"
  local token

  if ! token="$(read_token)"; then
    printf '还没有保存 API Token，请先在菜单中选择“设置/更新 API Token”。\n' >&2
    return 2
  fi

  curl -sS -X POST -H "Authorization: Bearer $token" "$API_BASE/$endpoint"
}

is_ok_response() {
  local body="$1"
  local ok

  ok="$(printf '%s' "$body" | json_value ok 2>/dev/null || true)"
  [ "$ok" = "true" ]
}

error_message() {
  local body="$1"
  local error

  error="$(printf '%s' "$body" | json_value error 2>/dev/null || true)"
  if [ -n "$error" ]; then
    printf '%s\n' "$error"
  else
    printf '%s\n' "$body"
  fi
}

cache_change_response() {
  local body="$1"
  local file dir

  file="$(state_file)"
  dir="$(dirname "$file")"
  mkdir -p "$dir"
  chmod 700 "$dir" 2>/dev/null || true

  python3 - "$file" "$body" <<'PY'
from datetime import datetime
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
body = sys.argv[2]

try:
    payload = json.loads(body)
except Exception:
    raise SystemExit(0)

state = {}
if path.exists():
    try:
        state = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        state = {}

state["updated_at"] = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

if payload.get("ok") is True:
    state.pop("last_error", None)
    if "uses_left" in payload:
        state["uses_left"] = payload["uses_left"]
    if "next_allowed_at" in payload:
        state["next_allowed_at"] = payload["next_allowed_at"]
elif "error" in payload:
    state["last_error"] = payload["error"]

path.write_text(json.dumps(state, ensure_ascii=False, indent=2) + "\n", encoding="utf-8")
PY
  chmod 600 "$file" 2>/dev/null || true
}

show_cached_quota() {
  local file
  file="$(state_file)"

  if [ ! -r "$file" ]; then
    printf 'API 剩余次数: 未知（成功换 IP 后会自动缓存）\n'
    return 0
  fi

  python3 - "$file" <<'PY'
from datetime import datetime
from pathlib import Path
import json
import sys

path = Path(sys.argv[1])
try:
    state = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("API 剩余次数: 未知（缓存文件读取失败）")
    raise SystemExit(0)

uses_left = state.get("uses_left")
if uses_left is None:
    print("API 剩余次数: 未知（成功换 IP 后会自动缓存）")
else:
    print(f"API 剩余次数: {uses_left}")

next_allowed_at = state.get("next_allowed_at")
if next_allowed_at:
    try:
        readable = datetime.fromtimestamp(int(next_allowed_at)).strftime("%Y-%m-%d %H:%M:%S")
    except Exception:
        readable = str(next_allowed_at)
    print(f"下次可换 IP 时间: {readable}")

if state.get("updated_at"):
    print(f"次数更新时间: {state['updated_at']}")
if state.get("last_error"):
    print(f"上次错误: {state['last_error']}")
PY
}

get_ip_plain() {
  local body ip

  body="$(api_post getIP)" || return $?
  if ! is_ok_response "$body"; then
    printf '查询失败: %s\n' "$(error_message "$body")" >&2
    return 1
  fi

  ip="$(printf '%s' "$body" | json_value ip 2>/dev/null || true)"
  if [ -z "$ip" ]; then
    printf '查询失败: API 返回中没有 ip 字段。\n' >&2
    return 1
  fi

  printf '%s\n' "$ip"
}

show_current_ip() {
  local ip

  if ip="$(get_ip_plain)"; then
    printf '当前 IP: %s\n' "$ip"
  fi
}

extract_script_version() {
  local file="$1"

  python3 - "$file" <<'PY'
from pathlib import Path
import re
import sys

path = Path(sys.argv[1])
text = path.read_text(encoding="utf-8", errors="ignore")
match = re.search(r'^VERSION=["\']?([^"\']+)["\']?', text, re.MULTILINE)
print(match.group(1) if match else "未知")
PY
}

update_download_url() {
  local url="$1"
  local stamp

  stamp="$(date +%s)"
  case "$url" in
    http://*|https://*)
      case "$url" in
        *\?*) printf '%s&cache=%s\n' "$url" "$stamp" ;;
        *) printf '%s?cache=%s\n' "$url" "$stamp" ;;
      esac
      ;;
    *)
      printf '%s\n' "$url"
      ;;
  esac
}

self_update() {
  local target target_dir tmp_file new_version download_url

  target="$(current_script_path)"
  target_dir="$(dirname "$target")"
  download_url="$(update_download_url "$UPDATE_URL")"

  printf '当前版本: %s\n' "$VERSION"
  printf '更新地址: %s\n' "$UPDATE_URL"
  printf '安装目标: %s\n\n' "$target"

  if [ ! -e "$target" ]; then
    printf '更新失败: 找不到当前脚本文件。\n'
    return 1
  fi

  if [ ! -w "$target" ] || [ ! -w "$target_dir" ]; then
    printf '更新失败: 没有写入权限。\n'
    printf '请使用 root 运行 boil，或重新执行在线安装命令:\n'
    printf 'curl -fsSL https://raw.githubusercontent.com/chnnic/Boil-Change-IP/main/install-online.sh | bash\n'
    return 1
  fi

  tmp_file="$(mktemp)" || {
    printf '更新失败: 无法创建临时文件。\n'
    return 1
  }

  printf '正在从 GitHub 下载最新版...\n'
  if ! curl -fsSL --noproxy '*' --connect-timeout 10 --max-time 30 "$download_url" -o "$tmp_file"; then
    rm -f "$tmp_file"
    printf '更新失败: 下载失败。\n'
    return 1
  fi

  if ! bash -n "$tmp_file"; then
    rm -f "$tmp_file"
    printf '更新失败: 下载到的脚本语法校验未通过，已取消覆盖。\n'
    return 1
  fi

  new_version="$(extract_script_version "$tmp_file")"

  if ! install -m 0755 "$tmp_file" "$target"; then
    rm -f "$tmp_file"
    printf '更新失败: 写入目标文件失败。\n'
    return 1
  fi

  rm -f "$tmp_file"
  printf '更新完成: %s\n' "$new_version"
}

ddns_find_manager() {
  local candidate

  if [ "${BOIL_DDNS_FORCE_HELPER:-0}" != "1" ]; then
    for candidate in \
      "/usr/local/bin/vps-tools" \
      "/usr/local/bin/v" \
      "/usr/local/bin/V" \
      "$(command -v vps-tools 2>/dev/null || true)" \
      "$(command -v v 2>/dev/null || true)" \
      "$(command -v V 2>/dev/null || true)"; do
      [ -n "$candidate" ] || continue
      [ -f "$candidate" ] || continue
      if grep -q -- "--ddns-menu" "$candidate" 2>/dev/null; then
        printf '%s\n' "$candidate"
        return 0
      fi
    done
  fi

  candidate="$(ddns_helper_file)"
  if [ -f "$candidate" ] && grep -q -- "--ddns-menu" "$candidate" 2>/dev/null; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

ddns_install_helper() {
  local target target_dir tmp_file download_url

  target="$(ddns_helper_file)"
  target_dir="$(dirname "$target")"
  download_url="$(update_download_url "$SSH_HARDENING_DDNS_URL")"

  mkdir -p "$target_dir" 2>/dev/null || {
    printf '无法创建目录: %s\n' "$target_dir"
    return 1
  }

  if [ ! -w "$target_dir" ]; then
    printf '没有写入权限: %s\n' "$target_dir"
    printf '请使用 root 运行，或设置 BOIL_DDNS_HELPER 指向可写路径。\n'
    return 1
  fi

  tmp_file="$(mktemp)" || {
    printf '无法创建临时文件。\n'
    return 1
  }

  printf '正在下载 SSH-Hardening DDNS 模块入口...\n'
  printf '来源: %s\n' "$SSH_HARDENING_DDNS_URL"
  if ! curl -fsSL --noproxy '*' --connect-timeout 10 --max-time 45 "$download_url" -o "$tmp_file"; then
    rm -f "$tmp_file"
    printf '下载失败。\n'
    return 1
  fi

  if ! bash -n "$tmp_file"; then
    rm -f "$tmp_file"
    printf '下载到的脚本语法校验失败，已取消安装。\n'
    return 1
  fi

  if ! grep -q -- "--ddns-menu" "$tmp_file" 2>/dev/null; then
    rm -f "$tmp_file"
    printf '下载到的脚本不包含 DDNS 菜单入口，已取消安装。\n'
    return 1
  fi

  if ! install -m 0755 "$tmp_file" "$target"; then
    rm -f "$tmp_file"
    printf '写入 DDNS 管理入口失败: %s\n' "$target"
    return 1
  fi

  rm -f "$tmp_file"
  printf 'DDNS 管理入口已安装: %s\n' "$target"
}

ddns_run_manager() {
  local mode="${1:-menu}"
  local manager

  manager="$(ddns_find_manager)" || return 1
  printf '调用 DDNS 管理入口: %s\n\n' "$manager"
  case "$mode" in
    install) bash "$manager" --ddns-install ;;
    run) bash "$manager" --ddns-run ;;
    status) bash "$manager" --ddns-status ;;
    log) bash "$manager" --ddns-log ;;
    *) bash "$manager" --ddns-menu ;;
  esac
}

ddns_module_menu() {
  local choice

  if ddns_find_manager >/dev/null 2>&1; then
    ddns_run_manager menu
    return $?
  fi

  printf '未检测到已安装的 SSH-Hardening DDNS 管理入口。\n'
  if [ -f /root/ddns.sh ]; then
    printf '检测到已有 DDNS 执行脚本: /root/ddns.sh\n'
    printf '可以安装管理入口后继续管理现有 DDNS 配置。\n'
  else
    printf '可以只安装 DDNS 模块入口，不安装 SSH-Hardening 主命令 vps-tools/v/V。\n'
  fi
  printf '\n'
  cat <<'EOF'
1) 安装 DDNS 管理入口并打开 DDNS 菜单
2) 安装 DDNS 管理入口并直接开始配置 DDNS
0) 返回主菜单
EOF
  printf '\n请选择: '
  IFS= read -r choice
  printf '\n'

  case "$choice" in
    1)
      ddns_install_helper && ddns_run_manager menu
      ;;
    2)
      ddns_install_helper && ddns_run_manager install
      ;;
    0|q|Q|"")
      return 0
      ;;
    *)
      printf '无效选择。\n'
      return 1
      ;;
  esac
}

trim_text() {
  python3 -c 'import sys; print(sys.stdin.read().strip())'
}

detect_public_ip() {
  local url ip

  for url in \
    "https://api.ipify.org" \
    "https://checkip.amazonaws.com" \
    "https://icanhazip.com"; do
    ip="$(curl -fsS --noproxy '*' --connect-timeout 5 --max-time 10 "$url" 2>/dev/null | trim_text || true)"
    if [ -n "$ip" ] && [[ "$ip" != *" "* ]]; then
      printf '%s\n' "$ip"
      return 0
    fi
  done

  printf '无法查询本机公网出口 IP。\n' >&2
  return 1
}

bool_text() {
  case "$1" in
    true) printf '是\n' ;;
    false) printf '否\n' ;;
    "") printf '未知\n' ;;
    *) printf '%s\n' "$1" ;;
  esac
}

ip_quality_dnsbl_report() {
  local ip="$1"

  python3 - "$ip" <<'PY'
import ipaddress
import socket
import sys

target = sys.argv[1]
lists = [
    ("Spamhaus ZEN", "zen.spamhaus.org"),
    ("Spamcop", "bl.spamcop.net"),
    ("SORBS", "dnsbl.sorbs.net"),
    ("Barracuda", "b.barracudacentral.org"),
]

try:
    ip = ipaddress.ip_address(target)
except ValueError:
    print("DNSBL 检测: IP 格式无效，已跳过")
    print("__DNSBL_HITS__=0")
    raise SystemExit(0)

if ip.version != 4:
    print("DNSBL 检测: 仅支持 IPv4，IPv6 已跳过")
    print("__DNSBL_HITS__=0")
    raise SystemExit(0)

reverse = ".".join(reversed(str(ip).split(".")))
socket.setdefaulttimeout(2)
hits = 0

print("DNSBL 检测:")
for label, zone in lists:
    query = f"{reverse}.{zone}"
    try:
        _, _, addresses = socket.gethostbyname_ex(query)
    except socket.gaierror:
        print(f"  {label}: 未命中")
        continue
    except socket.timeout:
        print(f"  {label}: 查询超时")
        continue
    except OSError as exc:
        print(f"  {label}: 查询失败 ({exc})")
        continue

    if any(addr.startswith("127.255.255.") for addr in addresses):
        print(f"  {label}: 查询受限")
        continue

    hits += 1
    print(f"  {label}: 命中 ({', '.join(addresses)})")

print(f"DNSBL 命中数: {hits}/{len(lists)}")
print(f"__DNSBL_HITS__={hits}")
PY
}

print_ip_quality_result() {
  local ip="$1"
  local body status error country region city isp org asn asname mobile proxy hosting
  local dnsbl_report dnsbl_hits score level

  printf 'IP 质量查询: %s\n' "$ip"
  printf '数据源: ip-api.com + DNSBL，本工具未使用 ping0.cc 数据。\n\n'

  body="$(curl -sS --noproxy '*' --connect-timeout 8 --max-time 15 "http://ip-api.com/json/$ip?fields=status,message,query,country,regionName,city,isp,org,as,asname,mobile,proxy,hosting" 2>/dev/null || true)"
  status="$(printf '%s' "$body" | json_value status 2>/dev/null || true)"

  if [ "$status" != "success" ]; then
    error="$(printf '%s' "$body" | json_value message 2>/dev/null || true)"
    if [ -n "$error" ]; then
      printf '基础信息查询失败: %s\n\n' "$error"
    else
      printf '基础信息查询失败。\n\n'
    fi
  else
    country="$(printf '%s' "$body" | json_value country 2>/dev/null || true)"
    region="$(printf '%s' "$body" | json_value regionName 2>/dev/null || true)"
    city="$(printf '%s' "$body" | json_value city 2>/dev/null || true)"
    isp="$(printf '%s' "$body" | json_value isp 2>/dev/null || true)"
    org="$(printf '%s' "$body" | json_value org 2>/dev/null || true)"
    asn="$(printf '%s' "$body" | json_value as 2>/dev/null || true)"
    asname="$(printf '%s' "$body" | json_value asname 2>/dev/null || true)"
    mobile="$(printf '%s' "$body" | json_value mobile 2>/dev/null || true)"
    proxy="$(printf '%s' "$body" | json_value proxy 2>/dev/null || true)"
    hosting="$(printf '%s' "$body" | json_value hosting 2>/dev/null || true)"

    printf '位置: %s %s %s\n' "${country:-未知}" "${region:-}" "${city:-}"
    printf 'ASN: %s\n' "${asn:-未知}"
    if [ -n "$asname" ]; then
      printf 'AS 名称: %s\n' "$asname"
    fi
    printf 'ISP: %s\n' "${isp:-未知}"
    printf '组织: %s\n' "${org:-未知}"
    printf '移动网络: %s\n' "$(bool_text "$mobile")"
    printf '代理/VPN/Tor 标记: %s\n' "$(bool_text "$proxy")"
    printf '机房/Hosting 标记: %s\n\n' "$(bool_text "$hosting")"
  fi

  dnsbl_report="$(ip_quality_dnsbl_report "$ip")"
  printf '%s\n\n' "$(printf '%s\n' "$dnsbl_report" | sed '/^__DNSBL_HITS__=/d')"
  dnsbl_hits="$(printf '%s\n' "$dnsbl_report" | sed -n 's/^__DNSBL_HITS__=//p' | tail -n 1)"
  dnsbl_hits="${dnsbl_hits:-0}"

  score=0
  [ "${proxy:-}" = "true" ] && score=$((score + 40))
  [ "${hosting:-}" = "true" ] && score=$((score + 30))
  if [[ "$dnsbl_hits" =~ ^[0-9]+$ ]] && [ "$dnsbl_hits" -gt 0 ]; then
    score=$((score + 40))
  fi

  if [ "$score" -ge 60 ]; then
    level="风险较高"
  elif [ "$score" -ge 30 ]; then
    level="一般"
  else
    level="较干净"
  fi

  printf '参考结论: %s\n' "$level"
  printf '说明: 结果仅供参考；不同平台风控规则不同，不能保证账号、支付或注册场景一定可用。\n'
}

ip_quality_menu() {
  local choice ip

  while true; do
    cat <<'EOF'
IP 质量查询
1) 查询 Boil 当前 IP 质量（需要 API Token）
2) 查询本机公网出口 IP 质量
3) 手动输入 IP 查询质量
0) 返回主菜单
EOF
    printf '\n请选择: '
    IFS= read -r choice
    printf '\n'

    case "$choice" in
      1)
        if ip="$(get_ip_plain)"; then
          print_ip_quality_result "$ip"
        fi
        return 0
        ;;
      2)
        if ip="$(detect_public_ip)"; then
          print_ip_quality_result "$ip"
        fi
        return 0
        ;;
      3)
        printf '请输入要查询的 IP: '
        IFS= read -r ip
        ip="$(printf '%s' "$ip" | trim_text)"
        if [ -z "$ip" ]; then
          printf 'IP 不能为空。\n'
        else
          print_ip_quality_result "$ip"
          return 0
        fi
        ;;
      0|q|Q)
        return 0
        ;;
      *)
        printf '无效选择。\n\n'
        ;;
    esac
  done
}

change_ip() {
  local wait_for_change="${1:-0}"
  local old_ip new_ip body message uses_left next_allowed_at readable start now

  if [ "$wait_for_change" = "1" ]; then
    old_ip="$(get_ip_plain 2>/dev/null || true)"
  fi

  body="$(api_post changeIP/)" || return $?
  cache_change_response "$body"

  if ! is_ok_response "$body"; then
    printf '换 IP 失败: %s\n' "$(error_message "$body")"
    return 1
  fi

  message="$(printf '%s' "$body" | json_value message 2>/dev/null || true)"
  uses_left="$(printf '%s' "$body" | json_value uses_left 2>/dev/null || true)"
  next_allowed_at="$(printf '%s' "$body" | json_value next_allowed_at 2>/dev/null || true)"

  if [ -n "$message" ]; then
    printf '%s\n' "$message"
  else
    printf '已提交更换 IP 请求。\n'
  fi

  if [ -n "$uses_left" ]; then
    printf 'API 剩余次数: %s\n' "$uses_left"
  fi

  if [ -n "$next_allowed_at" ]; then
    readable="$(format_time "$next_allowed_at")"
    printf '下次可换 IP 时间: %s\n' "$readable"
  fi

  if [ "$wait_for_change" != "1" ]; then
    return 0
  fi

  printf '等待 IP 变化'
  start="$(date +%s)"
  while true; do
    sleep 3
    printf '.'
    new_ip="$(get_ip_plain 2>/dev/null || true)"

    if [ -n "$new_ip" ] && [ "$new_ip" != "$old_ip" ]; then
      printf '\n新的 IP: %s\n' "$new_ip"
      return 0
    fi

    now="$(date +%s)"
    if [ $((now - start)) -ge 90 ]; then
      printf '\n等待超时，请稍后在菜单中查询当前 IP。\n'
      return 0
    fi
  done
}

show_token_status() {
  local token file

  file="$(token_file)"
  if token="$(read_token 2>/dev/null)"; then
    printf 'Token 状态: 已保存（%s）\n' "$(mask_token "$token")"
    if [ -n "${BOIL_TOKEN:-}" ]; then
      printf 'Token 来源: 环境变量 BOIL_TOKEN\n'
    else
      printf 'Token 文件: %s\n' "$file"
    fi
  else
    printf 'Token 状态: 未设置\n'
    printf 'Token 文件: %s\n' "$file"
  fi
}

pause_screen() {
  printf '\n按 Enter 返回菜单...'
  IFS= read -r _
}

clear_screen() {
  if command -v clear >/dev/null 2>&1; then
    clear
  else
    printf '\033c'
  fi
}

print_header() {
  printf '========================================\n'
  printf ' Boil Change IP 菜单 %s\n' "$VERSION"
  printf '========================================\n'
  show_token_status
  show_cached_quota
  printf '%s\n' '----------------------------------------'
}

menu_loop() {
  local choice

  while true; do
    clear_screen
    print_header
    cat <<'EOF'
1) 查询当前 IP
2) IP 质量查询
3) 更换 IP
4) 更换 IP 并等待新 IP
5) 查看 API 剩余次数缓存
6) 设置/更新 API Token
7) 查看 Token 保存位置
8) 删除已保存 Token
9) 更新脚本（从 GitHub 拉取）
10) DDNS 管理（SSH-Hardening 模块）
0) 退出
EOF
    printf '\n请选择: '
    IFS= read -r choice
    printf '\n'

    case "$choice" in
      1)
        show_current_ip
        pause_screen
        ;;
      2)
        ip_quality_menu
        pause_screen
        ;;
      3)
        change_ip 0
        pause_screen
        ;;
      4)
        change_ip 1
        pause_screen
        ;;
      5)
        show_cached_quota
        pause_screen
        ;;
      6)
        prompt_token
        pause_screen
        ;;
      7)
        printf 'Token 文件: %s\n' "$(token_file)"
        printf '状态缓存: %s\n' "$(state_file)"
        pause_screen
        ;;
      8)
        remove_token
        pause_screen
        ;;
      9)
        self_update
        pause_screen
        ;;
      10)
        ddns_module_menu
        pause_screen
        ;;
      0|q|Q)
        printf '已退出。\n'
        exit 0
        ;;
      *)
        printf '无效选择。\n'
        pause_screen
        ;;
    esac
  done
}

remove_token() {
  local file

  if [ -n "${BOIL_TOKEN:-}" ]; then
    printf '当前使用的是环境变量 BOIL_TOKEN，脚本不会删除环境变量。\n'
    return 0
  fi

  file="$(token_file)"
  if [ ! -e "$file" ]; then
    printf 'Token 文件不存在: %s\n' "$file"
    return 0
  fi

  rm -f "$file"
  printf '已删除 Token 文件: %s\n' "$file"
}

print_help() {
  cat <<EOF
Boil Change IP $VERSION

运行:
  boil

说明:
  默认进入菜单，可在菜单中查询 IP、查询 IP 质量、更换 IP、保存 Token、查看剩余次数缓存、从 GitHub 更新脚本。

命令:
  boil              打开菜单
  boil update       从 GitHub 拉取最新版并覆盖本地脚本
  boil version      显示版本号
  boil ddns         打开 SSH-Hardening DDNS 菜单
  boil ddns-install 只安装/配置 DDNS 模块

环境变量:
  BOIL_TOKEN       临时指定 API Token，不读取 Token 文件
  BOIL_TOKEN_FILE  指定 Token 文件
  BOIL_STATE_FILE  指定状态缓存文件
  BOIL_API_BASE    指定 API 地址，默认 https://ippanel.boil.network/api/v1
  BOIL_UPDATE_URL  指定更新下载地址
  BOIL_DDNS_URL    指定 SSH-Hardening DDNS 入口下载地址
  BOIL_DDNS_HELPER 指定 DDNS 管理入口保存路径
EOF
}

main() {
  require_deps

  case "${1:-}" in
    -h|--help|help)
      print_help
      ;;
    -v|--version|version)
      printf '%s\n' "$VERSION"
      ;;
    update|self-update)
      self_update
      ;;
    ddns)
      ddns_module_menu
      ;;
    ddns-install)
      if ! ddns_find_manager >/dev/null 2>&1; then
        ddns_install_helper || exit $?
      fi
      ddns_run_manager install
      ;;
    ddns-run)
      ddns_run_manager run
      ;;
    *)
      menu_loop
      ;;
  esac
}

main "$@"
